/* Simple +/-/* expression language; parser evaluates constant expressions on the fly*/
/**
 *  Package and Import Specifications
 */
import java_cup.runtime.*;

/**
 *  Usercode Components
 */
parser code {:
    // Connect this parser to a scanner!
    irScanner s;
    irParser(irScanner s){ this.s=s; }
:}

/* define how to connect to the scanner! */
scan with {: return s.next_token(); :};

/**
 *  Symbol Lists
 */


/* Terminals (tokens returned by the scanner). */
terminal            CONCAT, LPAREN, RPAREN, LCBRACKET, RCBRACKET, COMMA,
                    IF, ELSE, REVERSE, PREFIX;
terminal String     STRING_LITERAL, ID;        /*our scanner provides strings*/

/*  Non terminals */
non terminal s, function_decl, parameters, function_calls, function_call,  function_decls, fd_parameters, parameter;
non terminal function_body, if_body;
non terminal String     expr, nested_function_call;

/**
 *  Precedence Declarations
 */
precedence left IF, ELSE;
precedence left CONCAT;
precedence left REVERSE;


/**
 *  The Grammar Rules
 */

s ::= function_decls:fd function_calls:fc  {: System.out.println(
    "public class Translated {\n" +  "    public static void main(String[] args) {\n"
    + fc + "    }\n"
    + fd +
    "\n}") ; :} ;

function_decls ::=  function_decls:rest function_decl:fd {: RESULT = rest + "\n" + fd; :}
                    |function_decl:fd {: RESULT = fd;:}
                    ;

function_decl ::= ID:name LPAREN fd_parameters:p RPAREN LCBRACKET  function_body:body  RCBRACKET 
                {: RESULT = "    public static String "+ name + "(" + p + ") {\n" + body + "\n    }"; :}
                | ID:name LPAREN RPAREN LCBRACKET function_body:body RCBRACKET 
                {: RESULT = "    public static String "+ name + "() {\n" + body + "\n    }"; :}
                ;

fd_parameters ::= fd_parameters:rest COMMA ID:id {: RESULT =  rest + ", " + "String " + id; :}
                  | ID:id    {: RESULT = "String " + id; :}
                  ;

function_calls ::= function_calls:rest function_call:fc {: RESULT = rest + "" + fc; :}
                | function_call:fc {: RESULT = fc; :}
                ;

function_call ::=   ID:name LPAREN parameters:p RPAREN {: RESULT = "        System.out.println(" + name + "(" + p + "));\n"; :}
                    | ID:name LPAREN RPAREN {: RESULT = "        System.out.println(" + name + "());\n"; :}
                    ;

function_body ::= expr:e {: RESULT = "        return "+ e +";"; :}
                | IF LPAREN if_body:b RPAREN function_body:b1 ELSE function_body:b2 
                {: RESULT = "        if (" + b + ") {\n    " + b1 + "\n        } else {\n    " + b2 + "\n        }" ; :}
                ;


if_body ::= expr:id1 PREFIX expr:id2  {:RESULT = id1 + ".startsWith(" + id2 + ")";:}
            ;


expr ::= expr:e1 CONCAT expr:e2  {: RESULT = e1 + " + " + e2; :}
     | STRING_LITERAL:s          {: RESULT = "\"" + s + "\""; :}
     | ID:var                      {: RESULT = var; :}
     | nested_function_call:fc {: RESULT = fc; :}
     | REVERSE expr:e   {: RESULT = "new StringBuilder(" + e + ").reverse().toString()"; :}
     ;

parameters ::= parameters:rest COMMA parameter:p {: RESULT = rest + ", " + p; :}
             | parameter:p {: RESULT = p; :}
             ;

parameter ::= STRING_LITERAL:sl {: RESULT = "\"" + sl + "\""; :}
            | nested_function_call:fc {: RESULT = fc; :}
            ;

nested_function_call ::=   ID:name LPAREN parameters:p RPAREN {: RESULT = name + "(" + p + ")"; :}
                    | ID:name LPAREN RPAREN {: RESULT = name + "()"; :}
                    ;
